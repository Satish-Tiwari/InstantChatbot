# -----------------------------------------------
# Instant Chatbot Backend - Environment Configuration
# -----------------------------------------------

# --- Backend Security (JWT) ---
# Change this for production! Must be 256-bit safe.
JWT_SECRET=backend-secret-change-me-in-production-2024-must-be-256-bits!
JWT_EXPIRATION=86400000

# --- Global AI Configuration ---
# Options: openai, anthropic, google (failover logic will use others if primary fails)
AI_PROVIDER=openai

# --- OpenAI API ---
# Get key here: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (Claude) ---
# Get key here: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# --- Google (Gemini) ---
# Uses Vertex AI (requires gcloud auth application-default login)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1
GOOGLE_MODEL=gemini-1.5-flash

# --- PostgreSQL + PGVector ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=instantchatbot
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Infrastructure ---
SERVER_PORT=8081
CORS_ORIGINS=http://localhost:3000
ZIP_STORAGE_PATH=./generated-bots

# --- Crawler Settings ---
MAX_CRAWL_PAGES=50
MAX_CRAWL_DEPTH=3
RAG_TOP_K=5
