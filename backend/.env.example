# ═══════════════════════════════════════════════
# ChatGen Backend — Environment Configuration
# ═══════════════════════════════════════════════

# ─── OpenAI API (REQUIRED) ───
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Backend Secret Key (JWT signing — keep private!) ───
JWT_SECRET=backend-secret-change-me-in-production-2024-must-be-256-bits!
JWT_EXPIRATION=86400000

# ─── Spring AI Models ───
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── PostgreSQL + PGVector ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatgen
DB_USERNAME=chatgen
DB_PASSWORD=chatgen123

# ─── Crawler Settings ───
MAX_CRAWL_PAGES=50
MAX_CRAWL_DEPTH=3

# ─── Server ───
SERVER_PORT=8080
ZIP_STORAGE_PATH=./generated-bots
CORS_ORIGINS=http://localhost:3000
